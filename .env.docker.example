# Copy to .env.docker (gitignored) and fill in your REMOTE analyzer Postgres.
# Used by: docker run --env-file .env.docker ...
#
# analyser-api reads these via envconfig (config/config.go). They override
# config.yml. DB is the REMOTE analyzer Postgres (same one iotex-kit used to
# hit directly via ANALYZER_DATABASE_URL).

DB_DRIVER=postgres
DB_HOST=your-remote-analyzer-host
DB_PORT=5432
DB_USER=your-user
DB_PASSWORD=your-password
DB_NAME=your-dbname

# Read-only standby? AutoMigrate issues DDL and a standby rejects writes.
# Set true to skip the startup AutoMigrate. Safe to leave true for a
# read-only analyser deployment.
DB_SKIP_AUTO_MIGRATE=true

# Ports (defaults 8888 grpc / 8889 http). Leave as-is unless they clash.
GRPC_API_PORT=8888
HTTP_API_PORT=8889

# Chain gRPC endpoint (default api.iotex.one:443). Startup calls chainrpc.Init
# and hard-fails if unreachable.
CHAIN_GRPC_ENDPOINT=api.iotex.one:443
